USE_MOCK_AI=true
USE_MOCK_POI=true
USE_MOCK_ROUTE=true
USE_MOCK_WEATHER=true

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_TIMEOUT_MS=120000

POI_PROVIDER=mock
ROUTE_PROVIDER=mock
WEATHER_PROVIDER=mock

AMAP_API_KEY=
NEXT_PUBLIC_AMAP_JS_KEY=
NEXT_PUBLIC_AMAP_SECURITY_JS_CODE=

QWEATHER_BASE_URL=
QWEATHER_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI
# - USE_MOCK_AI=true 时，可先不配真实模型。
# - LLM_BASE_URL / LLM_API_KEY / LLM_MODEL / LLM_TIMEOUT_MS 用于服务端 AI 调用。
# - LLM_API_KEY 只放 .env.local 或部署平台 secret，不要提交到仓库。

# Frontend AMap JS SDK
# - NEXT_PUBLIC_AMAP_JS_KEY 是浏览器端高德 JS SDK Key，会暴露给前端。
# - NEXT_PUBLIC_AMAP_SECURITY_JS_CODE 只在高德 JS Key 配了安全密钥时使用。
# - 没配 NEXT_PUBLIC_AMAP_JS_KEY 时，地图会 fallback，但行程仍可正常查看。

# Server-side AMap Web Services
# - AMAP_API_KEY 是服务端 Web 服务 Key，只给 POI / Route Provider 用。
# - 不要把 AMAP_API_KEY 当成前端 JS SDK Key 使用。
# - 如果只想先看真实地图底图，可以只配 NEXT_PUBLIC_AMAP_JS_KEY，继续保持 POI / Route 为 mock。
# - 如果想让真实点位和路线质量更好，再把 USE_MOCK_POI / USE_MOCK_ROUTE 改为 false，并把 PROVIDER 设成 amap。

# Weather
# - WEATHER_PROVIDER / QWEATHER_API_KEY / QWEATHER_BASE_URL 用于天气服务。
# - USE_MOCK_WEATHER=true 时，可先不配天气 Key。

# Netlify
# - NEXT_PUBLIC_AMAP_JS_KEY 和 NEXT_PUBLIC_AMAP_SECURITY_JS_CODE 属于前端公开变量。
# - LLM_API_KEY / AMAP_API_KEY / QWEATHER_API_KEY 属于服务端 secret。

# Supabase
# - NEXT_PUBLIC_SUPABASE_URL 和 NEXT_PUBLIC_SUPABASE_ANON_KEY 可前端使用。
# - SUPABASE_SERVICE_ROLE_KEY 只能放服务端，部署平台中必须按 secret 管理。
# - 普通登录、保存、列表、详情、更新、删除链路使用 bearer token + anon key + RLS。
# - 不要提交 .env.local。
