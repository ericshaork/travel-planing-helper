USE_MOCK_AI=true
USE_MOCK_POI=true
USE_MOCK_ROUTE=true
USE_MOCK_WEATHER=true
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_TIMEOUT_MS=120000
POI_PROVIDER=mock
ROUTE_PROVIDER=mock
WEATHER_PROVIDER=mock
AMAP_API_KEY=

QWEATHER_BASE_URL=
QWEATHER_API_KEY=

# Real AI notes:
# - Qwen / 百炼请填写 OpenAI-compatible Base URL 到 LLM_BASE_URL
# - 真实 API Key 只放 .env.local，不要提交到仓库
# - Netlify 请在 Environment Variables 里配置，不要写进代码
# - 测试模型可用 qwen-turbo，较稳模型可用 qwen-plus
# - LLM_TIMEOUT_MS 默认 120000（120 秒），可按模型响应速度调大
